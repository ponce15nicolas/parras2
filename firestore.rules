rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /site/properties {
      allow read: if true;
      allow write: if request.auth != null &&
        (request.auth.token.email == 'ponce15nicolas@gmail.com' ||
          request.auth.token.email == 'azulparrastr@gmail.com');
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}