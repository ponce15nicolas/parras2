rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /properties/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && 
        (request.auth.token.email == 'ponce15nicolas@gmail.com' || 
         request.auth.token.email == 'azulparrastr@gmail.com');
    }
  }
}
